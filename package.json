{
  "name": "chronicle-engine",
  "version": "0.3.0",
  "private": true,
  "description": "An idle RPG where the adventurer lives her own life between check-ins, in a world that is different every time.",
  "type": "module",
  "main": "src/engine.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "sim": "node bin/run.js",
    "world": "node bin/world.js",
    "test": "node --test test/*.test.js",
    "serve": "node bin/serve.js"
  },
  "keywords": [
    "idle",
    "incremental",
    "rpg",
    "simulation",
    "emergent-narrative",
    "procedural-lore"
  ],
  "license": "UNLICENSED"
}
